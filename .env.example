POSTGRES_DB=hpcr_builder
POSTGRES_USER=hpcr
POSTGRES_PASSWORD=devpass
POSTGRES_PORT=5432
POSTGRES_DATA_DIR=./data/postgres

DATABASE_URL=postgres://hpcr:devpass@postgres:5432/hpcr_builder?sslmode=disable
MIGRATE_DATABASE_URL=postgres://hpcr:devpass@postgres:5432/hpcr_builder?sslmode=disable

SERVER_HOST=0.0.0.0
SERVER_PORT=8080
REVERSE_PROXY_PORT=8080

TOKEN_EXPIRY=24h
BCRYPT_COST=12
LOG_LEVEL=info
LOG_FORMAT=json
MAX_PAYLOAD_SIZE=52428800
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,null
CORS_ALLOW_ALL=false
TRUST_PROXY_HEADERS=false
REQUEST_TIMEOUT=30s

ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@hpcr-builder.local
ADMIN_PASSWORD=admin123
