# =============================================================================
# PostgreSQL Database Configuration
# =============================================================================
POSTGRES_DB=hpcr_builder
POSTGRES_USER=hpcr
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_PORT=5432
POSTGRES_DATA_DIR=./data/postgres
POSTGRES_UID=1000
POSTGRES_GID=1000
DATABASE_SSL_MODE=disable

# PgAdmin Configuration
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@hpcr-builder.dev
PGADMIN_DEFAULT_PASSWORD=change-me-pgadmin-password

# =============================================================================
# Database Connection Strings
# IMPORTANT: These must match the POSTGRES_* variables above
# =============================================================================
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:${POSTGRES_PORT}/${POSTGRES_DB}?sslmode=${DATABASE_SSL_MODE}
MIGRATE_DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:${POSTGRES_PORT}/${POSTGRES_DB}?sslmode=${DATABASE_SSL_MODE}

# =============================================================================
# Backend Server Configuration
# =============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Reverse Proxy Configuration
REVERSE_PROXY_PORT=8080
REVERSE_PROXY_TLS_PORT=8443
NGINX_CONF_PATH=./config/nginx/default.conf

# TLS Configuration (Required for Production)
# Generate certificates using: openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
#   -keyout ./config/nginx/certs/privkey.pem -out ./config/nginx/certs/fullchain.pem
TLS_CERT_PATH=./config/nginx/certs/fullchain.pem
TLS_KEY_PATH=./config/nginx/certs/privkey.pem

# =============================================================================
# Application Security Settings
# =============================================================================
TOKEN_EXPIRY=24h
BCRYPT_COST=12
LOG_LEVEL=info
LOG_FORMAT=json
MAX_PAYLOAD_SIZE=52428800
REQUEST_TIMEOUT=30s

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ALL=false
TRUST_PROXY_HEADERS=true

# =============================================================================
# Initial Admin User Configuration
# REQUIRED: These must be set before first deployment
# =============================================================================
ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@hpcr-builder.local
ADMIN_PASSWORD=change-me-admin-password

# =============================================================================
# HashiCorp Vault Configuration
# =============================================================================
# Key Management Provider (currently only 'vault' is supported)
KEY_PROVIDER=vault

# Vault Server Configuration
VAULT_ADDR=http://vault:8200
VAULT_PORT=8200
VAULT_NAMESPACE=

# Vault Authentication
# For development: use 'token' method with VAULT_TOKEN
# For production: use 'approle' method with VAULT_ROLE_ID and VAULT_SECRET_ID
VAULT_AUTH_METHOD=token
VAULT_ROLE_ID=
VAULT_SECRET_ID=
VAULT_TOKEN=dev-root-token

# Vault Secrets Engine Configuration
VAULT_TRANSIT_MOUNT=transit
VAULT_KV_MOUNT=secret
VAULT_REQUEST_TIMEOUT=10s

# Vault UI Configuration
VAULT_UI_PORT=8000
