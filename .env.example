POSTGRES_DB=hpcr_builder
POSTGRES_USER=hpcr
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_PORT=5432
POSTGRES_DATA_DIR=./data/postgres
POSTGRES_UID=1000
POSTGRES_GID=1000
DATABASE_SSL_MODE=disable
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@hpcr-builder.dev
PGADMIN_DEFAULT_PASSWORD=change-me-pgadmin-password

DATABASE_URL=postgres://hpcr:change-me-postgres-password@postgres:5432/hpcr_builder?sslmode=disable
MIGRATE_DATABASE_URL=postgres://hpcr:change-me-postgres-password@postgres:5432/hpcr_builder?sslmode=disable

SERVER_HOST=0.0.0.0
SERVER_PORT=8080
REVERSE_PROXY_PORT=8080
REVERSE_PROXY_TLS_PORT=8443
NGINX_CONF_PATH=./config/nginx/default.conf
TLS_CERT_PATH=./config/nginx/certs/fullchain.pem
TLS_KEY_PATH=./config/nginx/certs/privkey.pem

TOKEN_EXPIRY=24h
BCRYPT_COST=12
LOG_LEVEL=info
LOG_FORMAT=json
MAX_PAYLOAD_SIZE=52428800
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ALL=false
TRUST_PROXY_HEADERS=true
REQUEST_TIMEOUT=30s

ADMIN_NAME=System Admin
ADMIN_EMAIL=admin
ADMIN_PASSWORD=change-me-admin-password

# Key Management Provider: vault
KEY_PROVIDER=vault

# Vault Configuration (required for key management)
VAULT_ADDR=http://vault:8200
VAULT_NAMESPACE=
VAULT_AUTH_METHOD=token
VAULT_ROLE_ID=
VAULT_SECRET_ID=
VAULT_TOKEN=dev-root-token
VAULT_TRANSIT_MOUNT=transit
VAULT_KV_MOUNT=secret
VAULT_REQUEST_TIMEOUT=10s
VAULT_UI_PORT=8000
