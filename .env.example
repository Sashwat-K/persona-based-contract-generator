POSTGRES_DB=hpcr_builder
POSTGRES_USER=hpcr
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_PORT=5432
POSTGRES_DATA_DIR=./data/postgres
DATABASE_SSL_MODE=disable

DATABASE_URL=postgres://hpcr:change-me-postgres-password@postgres:5432/hpcr_builder?sslmode=disable
MIGRATE_DATABASE_URL=postgres://hpcr:change-me-postgres-password@postgres:5432/hpcr_builder?sslmode=disable

SERVER_HOST=0.0.0.0
SERVER_PORT=8080
REVERSE_PROXY_PORT=8080
REVERSE_PROXY_TLS_PORT=8443
NGINX_CONF_PATH=./config/nginx/default.conf
TLS_CERT_PATH=./config/nginx/certs/fullchain.pem
TLS_KEY_PATH=./config/nginx/certs/privkey.pem

TOKEN_EXPIRY=24h
BCRYPT_COST=12
LOG_LEVEL=info
LOG_FORMAT=json
MAX_PAYLOAD_SIZE=52428800
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ALL=false
TRUST_PROXY_HEADERS=true
REQUEST_TIMEOUT=30s

ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@hpcr-builder.local
ADMIN_PASSWORD=change-me-admin-password
