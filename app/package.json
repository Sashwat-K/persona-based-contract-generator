    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.3",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@carbon/charts": "^1.27.3",
    "@carbon/charts-react": "^1.27.3",
    "@carbon/icons-react": "^11.77.1",
    "@carbon/react": "^1.104.1",
    "axios": "^1.7.9",
    "d3": "^7.9.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
